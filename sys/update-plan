#! /usr/bin/env bash
BASEDIR=$(dirname $0); cd $BASEDIR

. ../env-vars

_require_var WORKSPACE_HOME
_require_var UPDATE_PLAN_FILE

__usage_page() {
    cat << EOF
Execute the update plan.

Usage: $(basename $0) [<option>]*
Option:
    -h: Displays this help message
EOF
    exit 0
}

while getopts "h" opt; do
    case "$opt" in
        h)
            __usage_page
            ;;
    esac
done

if [ -n "$( type -t uname )" ]; then
    uname -m && cat /etc/*release
fi

if [ -n "$( type -t hostnamectl )" ]; then
    echo >&2
    hostnamectl
fi

if [ -n "$( type -t sudo )" ]; then
    sudo -l 1>/dev/null
    if [ $? -ne 0 ] || ! [ "$( sudo whoami )" = "root" ]; then
        echo "Execute:" >&2
        echo "> su \$USER" >&2
        _stopped
    fi
fi

_print_cmds=()

if [ -f "$UPDATE_PLAN_FILE" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
        _cmd=$( echo "${line//[$'\t\r\n']}" )
        _exe=$( cut -d : -f 1 <<< "$_cmd" )

        if [ "$_exe" = "p" ]; then
            _cmd=$( echo "$_cmd" | cut -b 3- )
            _print_cmds+=( "$_cmd" )
        else
            echo >&2
            echo "Executing: [$_cmd]" >&2
            eval "$_cmd"
        fi
    done < $UPDATE_PLAN_FILE
fi

if [ ${#_print_cmds[*]} -gt 0 ]; then
    echo >&2
    echo "Execute these update commands if needed:" >&2

    for _cmd in "${_print_cmds[@]}"; do
        echo "> $_cmd" >&2
    done
fi

_completed
