#! /usr/bin/env bash

PWD=$(pwd)
# Files are backed by physical storage
TEMP_DIR=$(systemd-path temporary-large)
# Files are flushed out on each reboot
STEMP_DIR=$(systemd-path temporary)
# User profile
USER_HOME=$HOME

if [ ! "$(grep -in "ENV_VARS_FILE=*" ~/.bashrc)" ]; then
    echo "Specify environment variables file by defining the environment variable 'export ENV_VARS_FILE=...' in ~/.bashrc"
    exit 0
else
    eval "$( grep "ENV_VARS_FILE=*" ~/.bashrc | xargs )"
fi

if [ ! -f "$ENV_VARS_FILE" ]; then
    echo "Environment variables file not found: '$ENV_VARS_FILE'"
    exit 0
fi

. "$ENV_VARS_FILE"


_require_var() {
  local _var=${1:-}
  local _val_cmd="echo \$$_var"
  local _val=$(eval "$_val_cmd")

  if [ -z "$_val" ]; then
    echo "Undefined environment variable: $_var"
    exit 0
  fi
}

_back() {
    if [ -n "$PWD" ]; then
        cd $PWD
    fi
}

_completed() {
    echo ;
    echo "[Completed]: $0"

    _back

    exit 0
}

_stopped() {
    echo ;
    echo "[Process stopped]: $0"

    _back

    exit 0
}

_trim_separator() {
    echo "${1:-}" | sed 's/^\/*\|\/*$//g'
}

_trim_trailing_separator() {
    echo "${1:-}" | sed 's/\/*$//'
}

_kill_process() {
    local _name=${1:-}
    local _all_pids=$( ps -ef | grep "$_name" | grep -v grep | awk '{print $2}' )

    if [ -n "$_all_pids" ]; then
        echo "Stopping process '$_name'..."

        for pid in $_all_pids; do
            sudo kill -9 $pid
            waited=0
            while [ -e /proc/$pid ]; do
                sleep 1
                let "waited+=1"
                if [ $waited -eq 120 ]; then
                    echo -e "\nWaited two minutes, $pid is not responding to stop '$_name'"
                    exit 1
                fi
            done
            echo -e "\nStopped '$_name' running with PID $pid"
        done
    else
        echo "Process '$_name' is not running"
    fi
}
