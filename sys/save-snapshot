#! /usr/bin/env bash
BASEDIR=$(dirname $0); cd $BASEDIR

. ../env-vars

# http://www.gnu.org/software/bash/manual/html_node/Shell-Parameter-Expansion.html
: "${SNAPSHOTS_TO_KEEP:=1}"

__usage_page() {
    cat << EOF
Create snapshots of save files.

Usage: $(basename $0) [<option>]*
Option:
    -s: Source directory or file
    -k: Number of the snapshots to keep
    -r: Recovers save from snapshots
    -h: Displays this help message
EOF
    exit 0
}

_source=""
_keep=$SNAPSHOTS_TO_KEEP
_recover_flag=0

while getopts "s:k:rh" opt; do
    case "$opt" in
        s)
            _source="$OPTARG"
            ;;
        k)
            _keep=$OPTARG
            ;;
        r)
            _recover_flag=1
            ;;
        h)
            __usage_page
            ;;
    esac
done

if ! [ $_recover_flag -eq 1 ]; then
    $(command -v python3 || command -v python) "./.py/file_snapshot.py" -s "$_source" -k $_keep
else
    $(command -v python3 || command -v python) "./.py/file_snapshot.py" -s "$_source" --recover
fi

_completed
