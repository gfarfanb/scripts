#! /usr/bin/env bash
BASEDIR=$(dirname $0); cd $BASEDIR

. ../env-vars

_require_var OPEN_WEBUI_ENV
_require_var OPEN_WEBUI_PORT
_require_var OPEN_WEBUI_COMPOSE_FILE
_require_var OPEN_WEBUI_BACKUP_HOME
_require_var OPEN_WEBUI_BACKUP_TO_KEEP
_require_var OPEN_WEBUI_POSTGRESQL_USER
_require_var OPEN_WEBUI_POSTGRESQL_PASSWORD
_require_var OPEN_WEBUI_POSTGRESQL_SERVER
_require_var OPEN_WEBUI_DATABASE_NAME
_require_var OPEN_WEBUI_GITHUB_CLIENT_ID
_require_var OPEN_WEBUI_GITHUB_CLIENT_SECRET
_require_var COPILOT_ADAPTER_PORT
_require_var GITHUB_COPILOT_TOKEN
_require_var COPILOT_ADAPTER_API_URL
_require_var COPILOT_ADAPTER_API_VERSION
_require_var OLLAMA_SERVER
_require_var SEARXNG_PORT
_require_var SEARXNG_SERVER
_require_var OPEN_WEBUI_SEARXNG_SECRET
_require_var DOCLING_SERVER
_require_var DOCLING_PORT
_require_var TIKA_SERVER

__usage_page() {
    echo "Starts Open WebUI and the related services."
    echo ;
    echo "Usage: $(basename $0) [<option>]*"
    echo "Option:"
    echo "    -b: Backup Open WebUI"
    echo "    -a: Restore backup for Open WebUI"
    echo "    -e: Execute a container"
    echo "    -k: Kill a container"
    echo "    -t: Open the terminal for a containers"
    echo "    -l: Show the logs for a containers"
    echo "    -s: Stop all containers"
    echo "    -r: Remove all containers"
    echo "    -u: Update containers"
    echo "    -h: Displays this help message"
    exit 0
}

. ../dev/.libs/docker-fn

_default_compose_service_name=open-webui-$OPEN_WEBUI_ENV

_start_ollama() {
    if ! [ "$( systemctl is-active ollama )" = "active" ]; then
        ollama serve
    fi
}

_docker_compose() {
    OPEN_WEBUI_PORT=$OPEN_WEBUI_PORT \
        OLLAMA_SERVER=$OLLAMA_SERVER \
        SEARXNG_PORT=$SEARXNG_PORT \
        SEARXNG_SERVER=$SEARXNG_SERVER \
        SEARXNG_SECRET=$OPEN_WEBUI_SEARXNG_SECRET \
        OPEN_WEBUI_POSTGRESQL_USER=$OPEN_WEBUI_POSTGRESQL_USER \
        OPEN_WEBUI_POSTGRESQL_PASSWORD=$OPEN_WEBUI_POSTGRESQL_PASSWORD \
        OPEN_WEBUI_POSTGRESQL_SERVER=$OPEN_WEBUI_POSTGRESQL_SERVER \
        OPEN_WEBUI_DATABASE_NAME=$OPEN_WEBUI_DATABASE_NAME \
        OPEN_WEBUI_GITHUB_CLIENT_ID=$OPEN_WEBUI_GITHUB_CLIENT_ID \
        OPEN_WEBUI_GITHUB_CLIENT_SECRET=$OPEN_WEBUI_GITHUB_CLIENT_SECRET \
        COPILOT_ADAPTER_PORT=$COPILOT_ADAPTER_PORT \
        COPILOT_ADAPTER_GITHUB_TOKEN=$GITHUB_COPILOT_TOKEN \
        COPILOT_ADAPTER_API_URL=$COPILOT_ADAPTER_API_URL \
        COPILOT_ADAPTER_API_VERSION=$COPILOT_ADAPTER_API_VERSION \
        DOCLING_SERVER=$DOCLING_SERVER \
        DOCLING_PORT=$DOCLING_PORT \
        TIKA_SERVER=$TIKA_SERVER \
        docker compose -f $OPEN_WEBUI_COMPOSE_FILE $*
}

_start_openwebui() {
    local _update_flag=${1:-}

    _start_ollama

    _docker_compose up

    _wait_until_healthy open-webui-$OPEN_WEBUI_ENV

    if [ $_update_flag -eq 1 ]; then
        _update_container open-webui-$OPEN_WEBUI_ENV
        _update_container docling-serve-$OPEN_WEBUI_ENV
        _update_container searxng
        echo "Service disabled, skipped: '> _update_container tika'"

        _wait_until_healthy open-webui-$OPEN_WEBUI_ENV
    fi

    echo ;
    echo "> http://localhost:$OPEN_WEBUI_PORT"

    _completed
}

_backup_openwebui() {
    echo "Creating backup for open-webui-$OPEN_WEBUI_ENV..."

    docker run --rm -v open-webui-$OPEN_WEBUI_ENV:/data -v $OPEN_WEBUI_BACKUP_HOME:/backup \
        alpine tar czf /backup/openwebui-$(date +%Y%m%d).tar.gz data

    cd $OPEN_WEBUI_BACKUP_HOME

    _files_count=$( ls | wc -l )

    if [ $_files_count -gt $OPEN_WEBUI_BACKUP_TO_KEEP ]; then
        ls -t | tail --lines=+$(expr $OPEN_WEBUI_BACKUP_TO_KEEP + 1) | xargs -d '\n' rm
    fi

    _completed
}

_restore_openwebui() {
    echo "Restoring backup for open-webui-$OPEN_WEBUI_ENV..."

    _backups=( $( ls "$OPEN_WEBUI_BACKUP_HOME" -t ) )
    _length=${#_backups[@]}
    _last=$((_length-1))

    echo ;
    echo "Select a backup to recover:"
    for _idx in "${!_backups[@]}"; do
        _backup="${_backups[$_idx]}"

        if [ $_idx -eq $_last ]; then
            echo "$((_idx+1))) (default) $_backup "
        else
            echo "$((_idx+1))) $_backup"
        fi
    done
    read -p "backup-index> " _backup_idx

    if [ -z "$_backup_idx" ]; then
        _backup_idx=$_last
    else
        _backup_idx=$((_backup_idx-1))
    fi

    _backup="${_backups[$_backup_idx]}"

    if [ -z "$_backup" ]; then
        echo "Invalid backup index"
        _stopped
    fi

    _docker_compose stop open-webui-$OPEN_WEBUI_ENV

    docker run --rm -v open-webui-$OPEN_WEBUI_ENV:/data -v $OPEN_WEBUI_BACKUP_HOME:/backup \
        alpine sh -c "rm -rf /data/* && tar xzf /backup/$_backup -C /"

    _docker_compose run --rm open-webui-$OPEN_WEBUI_ENV

    _completed
}

_update_flag=0

while getopts "baektlsruh" opt; do
    case "$opt" in
        b)
            _backup_openwebui
            ;;
        a)
            _restore_openwebui
            ;;
        e)
            _run_compose_service
            ;;
        k)
            _stop_compose_service
            ;;
        t)
            _terminal_compose_service
            ;;
        l)
            _logs_compose_service
            ;;
        s)
            _stop_compose
            ;;
        r)
            _remove_compose
            ;;
        u)
            _update_flag=1
            ;;
        h)
            __usage_page
            ;;
    esac
done

_start_openwebui $_update_flag
