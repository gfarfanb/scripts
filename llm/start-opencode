#! /usr/bin/env bash
BASEDIR=$(dirname $0); cd $BASEDIR

. ../.libs/env-vars

_require_var OPENCODE_SERVER_PORT

__usage_page() {
    cat << EOF
Starts OpenCode as server.

Usage: $(basename $0) [<option>]*
Option:
    -h: Displays this help message
EOF
    exit 0
}

while getopts "h" opt; do
    case "$opt" in
        h)
            __usage_page
            ;;
    esac
done

opencode serve --port $OPENCODE_SERVER_PORT --hostname 0.0.0.0

_completed
