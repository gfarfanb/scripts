#! /usr/bin/env bash
BASEDIR=$(dirname $0); cd $BASEDIR

. ../env-vars

_require_var YT_DLP_VIDEO_OUTPUT_FOLDER
_require_var YT_DLP_COOKIES_DB_PARENT
_require_var SESSION_TEMP_DIR

__usage_page() {
    echo "Fetch video on MP4 format."
    echo ;
    echo "Usage: $(basename $0) [<option>]*"
    echo "Option:"
    echo "    -y <URL>:          YouTube resource URL"
    echo "    -r <resolution>:   Video resolution, currently"
    echo "                         supported: sd, hd (default), full-hd"
    echo "    -c:                Attach cookies to request"
    echo "    -p:                Pack MP4 files into a ZIP file and delete MP4 files"
    echo "    -m:                Move all ZIP files to 'DOWLOADS_HOME' location"
    echo "    -h:                Displays this help message"
    exit 0
}

_pack_videos() {
    cd "$YT_DLP_VIDEO_OUTPUT_FOLDER"

    if [ -n "$(find . -name '*.mp4')" ]; then
        local _last_zip_file="$(ls | grep .*\\.zip | sort -V | tail -1)"
        local _video_part="video"
        local _extension_part=".zip"
        local _audio_length=${#_video_part}
        local _extension_length=${#_extension_part}
        local _counter=0

        if [ -n "$_last_zip_file" ]; then
            _last_zip_file_length=${#_last_zip_file}
            _counter=${_last_zip_file:$_audio_length:$(($_last_zip_file_length-$_audio_length-$_extension_length))}
            _counter=$(($_counter+1))
        fi

        local _package=$_video_part$_counter$_extension_part

        zip -r $_package *.mp4
        echo "ZIP generated: $_package"

        rm -f *.mp4

        echo "MP4 files were cleaned"
    else
        echo "MP4 files not found"
    fi

    _completed
}

_move_outputs() {
    if [ -n "$(find $YT_DLP_VIDEO_OUTPUT_FOLDER -name '*.zip')" ]; then
        rsync -av --remove-source-files $YT_DLP_VIDEO_OUTPUT_FOLDER/*.zip "$DOWNLOADS_HOME"
        echo "ZIP files moved to: $DOWNLOADS_HOME"
    else
        echo "ZIP files not found"
    fi

    _completed
}

_create_youtube_cookies() {
    local _sql_file=$( ls -t $YT_DLP_COOKIES_DB_PARENT/*/cookies.sqlite | head -1 )

    if [ -z "$_sql_file" ]; then
        echo "SQLite file not found" >&2
        _stopped
    fi

    if [ ! -r "$_sql_file" ]; then
        echo "File $_sql_file is not readable" >&2
        _stopped
    fi

    local _tmp_file=$( mktemp "$SESSION_TEMP_DIR/cookies.sqlite.XXXXXXXXXX" )
    cat "$_sql_file" >> $_tmp_file

    local _sql="select host as domain,"
    _sql+=" case substr(host,1,1)='.' when 0 then 'false' else 'true' end as subdomains,"
    _sql+=" path,"
    _sql+=" case isSecure when 0 then 'false' else 'true' end as secure,"
    _sql+=" expiry,"
    _sql+=" name,"
    _sql+=" value"
    _sql+=" from moz_cookies mc"
    _sql+=" where mc.host = '.youtube.com';"

    sqlite3 -json $_tmp_file "$_sql" > "$SESSION_TEMP_DIR/json-cookies.json"

    rm -f $_tmp_file

    $(command -v python3 || command -v python) "$SCRIPTS_HOME/misc/.py/netscape_cookies.py" \
        -j "$SESSION_TEMP_DIR/json-cookies.json" \
        -n "$SESSION_TEMP_DIR/netscape-cookies.txt"

    rm -f "$SESSION_TEMP_DIR/json-cookies.json"

    echo "$SESSION_TEMP_DIR/netscape-cookies.txt"
}

_create_cookies() {
    local _source=${1:-}

    case "$_source" in
        youtube)
            echo $( _create_youtube_cookies )
            ;;
        *)
            echo ""
            ;;
    esac
}

_get_resolution() {
    local _resolution=${1:-}

    case "$_resolution" in
        sd)
            echo "480"
            ;;
        hd)
            echo "720"
            ;;
        full-hd)
            echo "1080"
            ;;
        *)
            echo "720"
            ;;
    esac
}

_download_video() {
    local _url=${1:-}
    local _resolution=$( _get_resolution ${2:-} )
    local _cookies=$( _create_cookies ${3:-} )

    cd "$YT_DLP_VIDEO_OUTPUT_FOLDER"

    if [ -f "$_cookies" ]; then
        yt-dlp -S "res:$_resolution" --recode-video "mp4" --cookies "$_cookies" --rm-cache-dir "$_url"
    else
        yt-dlp -S "res:$_resolution" --recode-video "mp4" --rm-cache-dir "$_url"
    fi

    echo ;
    [ $? -eq 0 ] && echo "Downloaded: $_url" >&2 || echo "Unable to download: $_url" >&2

    rm -f "$_cookies"
}

_cookies_flag=0
_resolution=""
_source=""

while getopts "y:r:cpmh" opt; do
    case "$opt" in
        y)
            _src_url="$OPTARG"
            _source="youtube"
            ;;
        r)
            _resolution="$OPTARG"
            ;;
        c)
            _cookies_flag=1
            ;;
        p)
            _pack_videos
            ;;
        m)
            _move_outputs
            ;;
        h)
            __usage_page
            ;;
    esac
done

if [ $_cookies_flag -ne 1 ]; then
    _source=""
fi

_download_video "$_src_url" "$_resolution" "$_source"

_completed
